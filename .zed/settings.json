// AI-free practice: edit predictions OFF, LSP completions + Biome format-on-save ON.
{
  "edit_predictions": { "provider": "none", "disabled_globs": ["**"] },
  "show_edit_predictions": false,

  "format_on_save": "on",

  "lsp": {
    "biome": {
      "settings": {
        "require_config_file": false
      }
    }
  },

  "languages": {
    "TypeScript": {
      "show_edit_predictions": false,
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.organizeImports.biome": true
      }
    },
    "TSX": {
      "show_edit_predictions": false,
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.organizeImports.biome": true
      }
    },
    "JavaScript": {
      "show_edit_predictions": false,
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      },
      "code_actions_on_format": {
        "source.organizeImports.biome": true
      }
    },
    "JSX": {
      "show_edit_predictions": false,
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "JSON": {
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    },
    "JSONC": {
      "formatter": {
        "external": {
          "command": "./node_modules/.bin/biome",
          "arguments": ["format", "--stdin-file-path", "{buffer_path}"]
        }
      }
    }
  }
}
